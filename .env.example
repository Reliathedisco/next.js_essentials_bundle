# ========================================
# DATABASE
# ========================================
# PostgreSQL (recommended for production)
DATABASE_URL="postgresql://user:password@localhost:5432/dbname?schema=public"
DATABASE_READ_REPLICA_URL="postgresql://user:password@localhost:5432/dbname?schema=public"

# MySQL alternative
# DATABASE_URL="mysql://user:password@localhost:3306/dbname"

# MongoDB alternative
# DATABASE_URL="mongodb://localhost:27017/dbname"

# Connection pooling settings
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ========================================
# AUTHENTICATION
# ========================================
# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-key-change-this"

# Session settings
SESSION_MAX_AGE=604800  # 7 days in seconds

# ========================================
# OAUTH PROVIDERS
# ========================================
# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/callback/google"

# GitHub OAuth
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# Discord OAuth
DISCORD_CLIENT_ID="your-discord-client-id"
DISCORD_CLIENT_SECRET="your-discord-client-secret"

# Facebook OAuth
FACEBOOK_CLIENT_ID="your-facebook-app-id"
FACEBOOK_CLIENT_SECRET="your-facebook-app-secret"

# Twitter/X OAuth
TWITTER_CLIENT_ID="your-twitter-client-id"
TWITTER_CLIENT_SECRET="your-twitter-client-secret"

# ========================================
# PAYMENT PROCESSING
# ========================================
# Stripe
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"

# Stripe Product/Price IDs
STRIPE_PRICE_ID_BASIC="price_basic_monthly"
STRIPE_PRICE_ID_PRO="price_pro_monthly"
STRIPE_PRICE_ID_ENTERPRISE="price_enterprise_monthly"

# PayPal
PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_CLIENT_SECRET="your-paypal-client-secret"
PAYPAL_MODE="sandbox"  # or "live" for production

# ========================================
# EMAIL SERVICES
# ========================================
# Resend
RESEND_API_KEY="re_your_resend_api_key"
EMAIL_FROM="noreply@yourdomain.com"
EMAIL_FROM_NAME="Your App Name"

# SendGrid
SENDGRID_API_KEY="SG.your_sendgrid_api_key"

# Mailgun
MAILGUN_API_KEY="your-mailgun-api-key"
MAILGUN_DOMAIN="mg.yourdomain.com"

# Amazon SES
AWS_SES_ACCESS_KEY_ID="your-aws-access-key"
AWS_SES_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_SES_REGION="us-east-1"

# SMTP (generic)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"

# ========================================
# FILE STORAGE
# ========================================
# AWS S3
AWS_S3_BUCKET_NAME="your-bucket-name"
AWS_S3_REGION="us-east-1"
AWS_S3_ACCESS_KEY_ID="your-access-key-id"
AWS_S3_SECRET_ACCESS_KEY="your-secret-access-key"

# Cloudflare R2
CLOUDFLARE_R2_ACCOUNT_ID="your-account-id"
CLOUDFLARE_R2_ACCESS_KEY_ID="your-access-key"
CLOUDFLARE_R2_SECRET_ACCESS_KEY="your-secret-key"
CLOUDFLARE_R2_BUCKET_NAME="your-bucket-name"

# Supabase Storage
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Uploadthing
UPLOADTHING_SECRET="sk_live_your_secret"
UPLOADTHING_APP_ID="your_app_id"

# ========================================
# BACKEND AS A SERVICE
# ========================================
# Supabase
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_KEY="your-supabase-service-key"

# Firebase
FIREBASE_API_KEY="your-firebase-api-key"
FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
FIREBASE_MESSAGING_SENDER_ID="123456789"
FIREBASE_APP_ID="1:123456789:web:abcdef"

# ========================================
# CACHING & QUEUE
# ========================================
# Redis
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD="your-redis-password"

# Upstash Redis (serverless)
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token"

# BullMQ / Queue
QUEUE_REDIS_URL="redis://localhost:6379"

# ========================================
# ANALYTICS & MONITORING
# ========================================
# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Vercel Analytics
NEXT_PUBLIC_VERCEL_ANALYTICS_ID="your-analytics-id"

# PostHog
NEXT_PUBLIC_POSTHOG_KEY="phc_your_posthog_key"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# Mixpanel
NEXT_PUBLIC_MIXPANEL_TOKEN="your-mixpanel-token"

# Sentry
NEXT_PUBLIC_SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"
SENTRY_AUTH_TOKEN="your-sentry-auth-token"
SENTRY_ORG="your-org-slug"
SENTRY_PROJECT="your-project-slug"

# LogRocket
NEXT_PUBLIC_LOGROCKET_APP_ID="your-app/your-project"

# ========================================
# SEARCH
# ========================================
# Algolia
NEXT_PUBLIC_ALGOLIA_APP_ID="your-app-id"
NEXT_PUBLIC_ALGOLIA_SEARCH_API_KEY="your-search-key"
ALGOLIA_ADMIN_API_KEY="your-admin-key"

# Meilisearch
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY="your-master-key"

# Typesense
TYPESENSE_HOST="localhost"
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL="http"
TYPESENSE_API_KEY="your-api-key"

# ========================================
# AI & ML SERVICES
# ========================================
# OpenAI
OPENAI_API_KEY="sk-your-openai-api-key"
OPENAI_ORGANIZATION_ID="org-your-org-id"

# Anthropic Claude
ANTHROPIC_API_KEY="sk-ant-your-api-key"

# Google AI
GOOGLE_AI_API_KEY="your-google-ai-key"

# Replicate
REPLICATE_API_TOKEN="your-replicate-token"

# Hugging Face
HUGGINGFACE_API_KEY="hf_your_api_key"

# ========================================
# SMS & COMMUNICATIONS
# ========================================
# Twilio
TWILIO_ACCOUNT_SID="your-account-sid"
TWILIO_AUTH_TOKEN="your-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"

# Vonage (formerly Nexmo)
VONAGE_API_KEY="your-api-key"
VONAGE_API_SECRET="your-api-secret"

# ========================================
# WEBHOOKS & INTEGRATIONS
# ========================================
# Webhook secret for verifying incoming webhooks
WEBHOOK_SECRET="your-webhook-secret-key"

# Slack
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/YOUR/WEBHOOK/URL"
SLACK_BOT_TOKEN="xoxb-your-bot-token"

# Discord
DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/YOUR/WEBHOOK"

# GitHub
GITHUB_WEBHOOK_SECRET="your-github-webhook-secret"
GITHUB_PERSONAL_ACCESS_TOKEN="ghp_your_personal_access_token"

# ========================================
# CMS & CONTENT
# ========================================
# Contentful
CONTENTFUL_SPACE_ID="your-space-id"
CONTENTFUL_ACCESS_TOKEN="your-access-token"
CONTENTFUL_PREVIEW_TOKEN="your-preview-token"

# Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID="your-project-id"
NEXT_PUBLIC_SANITY_DATASET="production"
SANITY_API_TOKEN="your-api-token"

# Strapi
STRAPI_API_URL="http://localhost:1337"
STRAPI_API_TOKEN="your-strapi-token"

# ========================================
# DEPLOYMENT & INFRASTRUCTURE
# ========================================
# Vercel
VERCEL_TOKEN="your-vercel-token"
VERCEL_ORG_ID="your-org-id"
VERCEL_PROJECT_ID="your-project-id"

# Railway
RAILWAY_TOKEN="your-railway-token"

# Fly.io
FLY_API_TOKEN="your-fly-token"

# Docker
DOCKER_REGISTRY="registry.hub.docker.com"
DOCKER_USERNAME="your-username"
DOCKER_PASSWORD="your-password"

# ========================================
# FEATURE FLAGS
# ========================================
# LaunchDarkly
LAUNCHDARKLY_SDK_KEY="sdk-your-key"

# Split.io
SPLIT_IO_API_KEY="your-split-api-key"

# ========================================
# RATE LIMITING & SECURITY
# ========================================
# Arcjet (rate limiting, bot protection)
ARCJET_KEY="your-arcjet-key"

# Clerk (authentication)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_your_key"
CLERK_SECRET_KEY="sk_test_your_key"

# ========================================
# MISC SERVICES
# ========================================
# Cloudflare
CLOUDFLARE_API_TOKEN="your-cloudflare-token"
CLOUDFLARE_ZONE_ID="your-zone-id"

# Mapbox
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN="pk.your_mapbox_token"

# Geocoding
GOOGLE_MAPS_API_KEY="your-google-maps-key"

# Unsplash
UNSPLASH_ACCESS_KEY="your-unsplash-access-key"

# ========================================
# APPLICATION SETTINGS
# ========================================
# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# Environment
NODE_ENV="development"  # development | production | test

# App metadata
NEXT_PUBLIC_APP_NAME="Your App Name"
NEXT_PUBLIC_APP_DESCRIPTION="Your app description"

# Feature flags (app-specific)
FEATURE_BETA_ENABLED=false
FEATURE_MAINTENANCE_MODE=false

# ========================================
# SECURITY
# ========================================
# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS="http://localhost:3000,https://yourdomain.com"

# API rate limits
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes

# Cookie settings
COOKIE_SECURE=false  # Set to true in production with HTTPS
COOKIE_SAME_SITE="lax"  # strict | lax | none

# ========================================
# DEVELOPMENT TOOLS
# ========================================
# Debug mode
DEBUG=false
VERBOSE_LOGGING=false

# Disable telemetry
NEXT_TELEMETRY_DISABLED=1
